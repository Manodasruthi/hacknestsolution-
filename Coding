#include<stdio.h>
#include<string.h>
#define max 100
struct Student {
    int Id;
    char name[20];
    char dept[10];
    int age;
    int year;
    char phone[12];
    int m1,m2,m3;
};
int count=0;
struct Student students[max];

int findId(int id){
    for(int i=0;i<count;i++){
        if(students[i].Id==id){
            return i;
        }
    }
    return -1;
}
