void displayStudent(){
    if(count==0){
        printf("No record Found!!");
        return;
    }
    for(int i=0;i<count;i++){
        displayspecific(students[i]);
    }
}
void search(){
    if(count==0){
        printf("No Records found");
        return;
    }
    int choice,index,id;
    char name[20];
    printf("1.search by ID \n2.search by name\nEnter the choice :");
    scanf("%d",&choice);
    if(choice==1){
        if(count==0){
            printf("No Student Records");
            return;
        }
        printf("Enter ID to search :");
        scanf("%d",&id);
        index=findId(id);
        displayspecific(students[index]);
    }
    else if(choice==2){
        if(count==0){
            printf("No Student Records");
            return;
        }
        getchar();
        printf("Enter name to search :");
        fgets(name,sizeof(name),stdin);
        name[strcspn(name,"\n")]='\0';
        for(index=0;index<count;index++){
            if(strcmp(students[index].name,name)==0){
                break;
            }
        }
        if(index==count){
            printf("Invalid name");
            return;
        }
        printf("Student Found\n");
        displayspecific(students[index]);
    }
    else{
        printf("Student Not Student");
        return;
    }
}
void deleteStudent(){
    if(count==0){
        printf("No Records Found");
        return;
    }
    int id;
    printf("Enter the ID to delete :");
    scanf("%d",&id);
    int index=findId(id);
    if(index==-1){
        printf("Student Not Found!!");
        return;
    }
    for(int i=0;i<count-1;i++){
        students[i]=students[i+1];
    }
    count--;
    printf("Student Deleted Successfully..");
}
